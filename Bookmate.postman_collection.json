    {
      "name": "Library",
      "item": [
        {
          "name": "List Library",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/library/"
          }
        },
        {
          "name": "Add Book To Library",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('libraryId', data.id);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/library/?book_id={{bookId}}&status=reading",
              "host": ["{{baseUrl}}"],
              "path": ["api", "library", ""],
              "query": [
                { "key": "book_id", "value": "{{bookId}}" },
                { "key": "status", "value": "reading" }
              ]
            }
          }
        },
        {
          "name": "Update Library Status",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/api/library/{{libraryId}}/status?status=completed",
              "host": ["{{baseUrl}}"],
              "path": ["api", "library", "{{libraryId}}", "status"],
              "query": [
                { "key": "status", "value": "completed" }
              ]
            }
          }
        },
        {
          "name": "Delete Library Item",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "DELETE",
            "url": "{{baseUrl}}/api/library/{{libraryId}}"
          }
        }
      ]
