    "name": "Bookmate",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Complete Bookmate backend collection with auth, books, library, AI chat, marketplace, institutions, corporate clubs, and community groups."
