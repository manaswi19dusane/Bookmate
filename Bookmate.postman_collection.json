    { "key": "registerPassword", "value": "Validator123!" },
    { "key": "seedUserEmail", "value": "john.doe@example.com" },
    { "key": "seedUserPassword", "value": "SecurePass123!" }
  ],
  "item": [
    {
      "name": "Auth and Users",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{registerEmail}}\",\n  \"password\": \"{{registerPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/users/register"
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('token', data.access_token);",
                  "pm.collectionVariables.set('userId', data.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{registerEmail}}\",\n  \"password\": \"{{registerPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/users/login"
          }
        },
        {
          "name": "Login Seeded User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('token', data.access_token);",
                  "pm.collectionVariables.set('userId', data.user.id);"
                ]
