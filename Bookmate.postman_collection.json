              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"genre\": \"Mystery\",\n  \"author\": \"Agatha Christie\",\n  \"book_id\": \"{{bookId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/users/preferences"
          }
        },
        {
          "name": "List Interactions",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
              ]
            },
            "method": "GET",
            "url": "{{baseUrl}}/api/interactions"
          }
        },
        {
          "name": "Create Interaction",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{token}}", "type": "string" }
