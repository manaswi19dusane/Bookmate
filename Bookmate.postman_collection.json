  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:8000" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "bookId", "value": "" },
    { "key": "libraryId", "value": "" },
    { "key": "institutionId", "value": "" },
    { "key": "corporateClubId", "value": "" },
    { "key": "communityGroupId", "value": "" },
    { "key": "marketplaceId", "value": "" },
